# RafRaf — environment template. Copy to .env.local and fill in real values.
# Only NEXT_PUBLIC_* values are exposed to the browser; everything else is server-only.

# ── Supabase (public — safe for browser, RLS protects data) ──────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Supabase (SERVER ONLY — bypasses RLS, must never reach the client) ────────
SUPABASE_SERVICE_ROLE_KEY=

# ── Google Sheets/Drive backup (SERVER ONLY) — Phase 7 ───────────────────────
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste the PEM as a single line with literal \n between lines (quotes optional).
GOOGLE_PRIVATE_KEY=
# Master sheet id. Consumer service accounts have no Drive storage and can't
# CREATE sheets, so create it manually and share it (Editor) with the SA email,
# then run scripts/create-master-sheet.mjs to verify. Paste the id here.
RAFRAF_MASTER_SHEET_ID=
# Optional: a Google Workspace Shared Drive id. If set, the service account
# creates the master + per-merchant sheets inside it (no SA storage needed).
RAFRAF_SHARED_DRIVE_ID=
# Shared secret for the Vercel cron endpoints (/api/cron/*). Vercel sends it as
# `Authorization: Bearer <CRON_SECRET>`. Use a long random string.
CRON_SECRET=

# ── Notifications — Phase 8 ──────────────────────────────────────────────────
# PRIMARY: Telegram Bot (free, official, no approval). Create a bot via @BotFather.
# See docs/telegram-bot-setup.md.
TELEGRAM_BOT_TOKEN=
# A secret you choose; passed to setWebhook and echoed by Telegram in the
# X-Telegram-Bot-Api-Secret-Token header to /api/telegram/webhook.
TELEGRAM_WEBHOOK_SECRET=
# Admin's Telegram chat id (backup-failure alerts). DM the bot /start to get it.
RAFRAF_ADMIN_CHAT_ID=
# Public bot username (no @) — renders an "open bot" link in Settings.
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# SECONDARY: WhatsApp via Green API (optional — selectable per merchant later).
GREEN_API_ID_INSTANCE=
GREEN_API_TOKEN=
# Optional instance host (e.g. https://7105.api.greenapi.com); defaults to
# https://api.green-api.com.
GREEN_API_BASE_URL=
# Admin WhatsApp number (no +) — fallback for admin alerts when no Telegram.
RAFRAF_ADMIN_PHONE=

# Secret for the Supabase low-stock Database Webhook → /api/webhooks/low-stock
# (must match the webhook's `x-webhook-secret` header).
WHATSAPP_WEBHOOK_SECRET=

# ── Admin path protection — Phase 10 ─────────────────────────────────────────
# Comma-separated IP allowlist for /rafraf-admin (the superadmin dashboard).
# When EMPTY the IP layer is skipped (dev/before configured) — auth + the
# superadmin role check still apply. Set your office/home IPs in production.
# (The superadmin user is whoever has merchants.role='superadmin' — set it with:
#  UPDATE merchants SET role='superadmin' WHERE id='<your-auth-uid>'; )
ADMIN_ALLOWED_IPS=

# ── Admin secret path — unguessable admin URL ────────────────────────────────
# The superadmin dashboard mounts at /$ADMIN_SECRET_PATH (e.g. → /r9x7k2mq8p3control).
# The internal route (/rafraf-admin) returns 404 from outside. EMPTY ⇒ admin
# unreachable (safe default). Use a long random value; changing it needs a
# dev-server restart / redeploy (middleware reads the env at startup).
ADMIN_SECRET_PATH=

# ── Rate limiting (Upstash Redis) (SERVER ONLY) — Phase 9 ────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── AI layer (SERVER ONLY) — Phase 12 ────────────────────────────────────────
# Anthropic Claude API key. PLACEHOLDER — the AI endpoints return mock data until
# this is set and lib/ai/claude.ts is wired. AI features are gated to the smart plan.
ANTHROPIC_API_KEY=

# ── Email (Resend) (SERVER ONLY) ─────────────────────────────────────────────
# Transactional email (welcome) via the Resend API. Also set Supabase Auth to send
# its confirm/reset emails over Resend SMTP — see docs/email-setup.md.
RESEND_API_KEY=
# Verified sender (the domain must be verified in Resend). e.g. RafRaf <noreply@yourdomain.com>
EMAIL_FROM=

# ── Images (Cloudinary) ──────────────────────────────────────────────────────
# Optional product images + store logo. Uploads are SIGNED server-side (the secret
# never reaches the client); the browser uploads directly to Cloudinary. See
# docs/cloudinary-setup.md. CLOUD_NAME is also exposed publicly to build URLs.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
